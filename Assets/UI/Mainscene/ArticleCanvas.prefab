  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uBCF4\uD638\uAD6C \uBBF8\uCC29\uC6A9 \uC0C1\uD0DC\uC5D0\uC11C \uB4DC\uB9B4
    \uC791\uC5C5 \uC911 \uC0AC\uACE0 \uBC1C\uC0DD\r\n\r\n\uACF5\uC7A5 \uC124\uBE44
    \uC810\uAC80 \uC911 \uC791\uC5C5\uC790\uAC00 \uC804\uB3D9 \uB4DC\uB9B4\uC744
    \uC0AC\uC6A9\uD574 \uAE08\uC18D \uBD80\uD488\uC744 \uAC00\uACF5\uD558\uB358 \uC911
    \uC0AC\uACE0\uAC00 \uBC1C\uC0DD\uD588\uB2E4.\r\n\r\n\uC791\uC5C5\uC790\uB294
    \uC791\uC5C5 \uC804 <u><color=#FFD966>\uBCF4\uC548\uACBD\uACFC \uC7A5\uAC11 \uB4F1
    \uBCF4\uD638\uAD6C\uB97C \uCC29\uC6A9\uD558\uC9C0 \uC54A\uC740 \uC0C1\uD0DC</color></u>\uC600\uC73C\uBA70,
    \uB300\uC0C1\uBB3C\uC744 \uCDA9\uBD84\uD788 \uACE0\uC815\uD558\uC9C0 \uC54A\uACE0
    \uC791\uC5C5\uC744 \uC2DC\uC791\uD588\uB2E4.\r\n\r\n\uC791\uC5C5 \uC911 \uB4DC\uB9B4
    \uBE44\uD2B8\uAC00 \uD45C\uBA74\uC5D0 \uBE44\uC2A4\uB4EC\uD788 \uB2FF\uC73C\uBA74\uC11C
    \uBBF8\uB044\uB7EC\uC84C\uACE0, \uAC15\uD55C \uC800\uD56D\uC73C\uB85C \uC778\uD574
    \uC190\uBAA9\uC774 \uC21C\uAC04\uC801\uC73C\uB85C \uAEBE\uC774\uB294 <u><color=#FF6666>\uD0A5\uBC31
    \uC704\uD5D8 \uC0C1\uD669</color></u>\uC774 \uBC1C\uC0DD\uD588\uB2E4.\r\n\r\n\uB610\uD55C
    \uB4DC\uB9B4\uC744 \uBAB8\uC5D0 \uB108\uBB34 \uAC00\uAE4C\uC774 \uBD99\uC5EC
    \uC0AC\uC6A9\uD558\uBA74\uC11C \uC637\uC790\uB77D\uC774 \uD68C\uC804\uBD80 \uADFC\uCC98\uB85C
    \uC811\uADFC\uD574 <u><color=#FF6666>\uB9D0\uB9BC \uC0AC\uACE0 \uC704\uD5D8</color></u>\uB3C4
    \uD655\uC778\uB418\uC5C8\uB2E4.\r\n\r\n\uC791\uC5C5 \uC885\uB8CC \uD6C4 \uC791\uC5C5\uC790\uB294
    \uC794\uC7AC\uBB3C\uC744 \uC190\uC73C\uB85C \uC9C1\uC811 \uC81C\uAC70\uD558\uB824
    \uD588\uACE0, \uB0A0\uCE74\uB85C\uC6B4 \uAE08\uC18D \uC870\uAC01\uC5D0 \uC758\uD574
    \uC190 \uBD80\uC704\uC5D0 \uC0C1\uCC98\uB97C \uC785\uC5C8\uB2E4.\r\n\r\n\uC548\uC804
    \uB2F4\uB2F9\uC790\uB294 \u201C\uB4DC\uB9B4 \uC791\uC5C5 \uC804\uC5D0\uB294 \uBC18\uB4DC\uC2DC
    \uBCF4\uD638\uAD6C\uB97C \uCC29\uC6A9\uD558\uACE0, \uB300\uC0C1\uBB3C\uC744 \uACE0\uC815\uD55C
    \uB4A4 \uC62C\uBC14\uB978 \uAC01\uB3C4\uB85C \uC791\uC5C5\uD574\uC57C \uD55C\uB2E4.
    \uC794\uC7AC\uBB3C\uC740 \uC190\uC774 \uC544\uB2CC \uBE0C\uB7EC\uC2DC\uB098 \uC804\uC6A9
    \uB3C4\uAD6C\uB85C \uC81C\uAC70\uD574\uC57C \uD55C\uB2E4\u201D\uACE0 \uC124\uBA85\uD588\uB2E4."
