--- !u!114 &3751912393677799415
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 3735945124760905914}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uADF8\uB77C\uC778\uB354 \uC808\uB2E8 \uC791\uC5C5 \uC911 \uD30C\uD3B8
    \uBE44\uC0B0 \uC0AC\uACE0 \uBC1C\uC0DD\r\n\r\n\uACF5\uC7A5 \uC124\uBE44 \uC815\uBE44
    \uC911 \uC791\uC5C5\uC790\uAC00 \uADF8\uB77C\uC778\uB354\uB97C \uC0AC\uC6A9\uD574
    \uCCA0\uD310\uC744 \uC808\uB2E8\uD558\uB358 \uC911 \uC0AC\uACE0\uAC00 \uBC1C\uC0DD\uD588\uB2E4.\r\n\r\n\uC791\uC5C5\uC790\uB294
    \uC791\uC5C5 \uC804 \uBCF4\uD638\uAD6C\uB97C \uCC29\uC6A9\uD558\uC9C0 \uC54A\uC740
    \uC0C1\uD0DC\uC600\uC73C\uBA70, \uADF8\uB77C\uC778\uB354 \uC0AC\uC6A9 \uC804
    \uC808\uB2E8\uC11D\uC758 \uC0C1\uD0DC\uC640 \uC791\uC5C5 \uC790\uC138\uB97C \uCDA9\uBD84\uD788
    \uD655\uC778\uD558\uC9C0 \uC54A\uC558\uB2E4.\r\n\r\n\uC791\uC5C5 \uC911 \uC791\uC5C5\uC790\uAC00
    \uADF8\uB77C\uC778\uB354\uB97C \uBAB8\uC5D0 \uC9C0\uB098\uCE58\uAC8C \uAC00\uAE4C\uC774
    \uBD99\uC5EC \uC0AC\uC6A9\uD558\uBA74\uC11C <u><color=#FF6666>\uBD88\uAF43\uACFC
    \uD30C\uD3B8\uC774 \uC2E0\uCCB4 \uBC29\uD5A5\uC73C\uB85C \uBE44\uC0B0\uD558\uB294
    \uC704\uD5D8 \uC0C1\uD669</color></u>\uC774 \uBC1C\uC0DD\uD588\uB2E4.\r\n\r\n\uB610\uD55C
    \uADF8\uB77C\uC778\uB354\uAC00 \uCCA0\uD310\uC5D0 \uBE44\uC2A4\uB4EC\uD788 \uB2FF\uC73C\uBA74\uC11C
    \uC808\uB2E8\uC11D\uC5D0 \uAC15\uD55C \uC800\uD56D\uC774 \uAC78\uB838\uACE0,
    \uC7A5\uBE44\uAC00 \uC21C\uAC04\uC801\uC73C\uB85C \uD280\uC5B4 \uC624\uB974\uB294
    <u><color=#FF6666>\uD0A5\uBC31 \uC704\uD5D8</color></u>\uC774 \uD655\uC778\uB418\uC5C8\uB2E4.\r\n\r\n\uC774\uD6C4
    \uC791\uC5C5\uC790\uAC00 \uC7A5\uBE44\uB97C \uC81C\uC5B4\uD558\uC9C0 \uBABB\uD574
    \uD68C\uC804 \uC911\uC778 \uC808\uB2E8\uBD80\uAC00 \uC190\uACFC \uC5BC\uAD74
    \uAC00\uAE4C\uC774 \uC811\uADFC\uD588\uC73C\uBA70, <u><color=#FF6666>\uC2E0\uCCB4\uBD80\uC704
    \uC808\uB2E8 \uBC0F \uC808\uC0C1 \uC0AC\uACE0</color></u>\uB85C \uC774\uC5B4\uC9C8
    \uC218 \uC788\uB294 \uC0C1\uD669\uC774 \uBC1C\uC0DD\uD588\uB2E4.\r\n\r\n\uD604\uC7A5
    \uAD00\uB9AC\uC790\uB294 \u201C\uADF8\uB77C\uC778\uB354 \uC791\uC5C5 \uC804\uC5D0\uB294
    \uBC18\uB4DC\uC2DC \uBCF4\uD638\uAD6C\uB97C \uCC29\uC6A9\uD558\uACE0, \uC808\uB2E8\uC11D
    \uC0C1\uD0DC\uC640 \uC791\uC5C5 \uAC01\uB3C4\uB97C \uD655\uC778\uD574\uC57C \uD55C\uB2E4.
    \uC791\uC5C5 \uC911\uC5D0\uB294 \uC7A5\uBE44\uB97C \uBAB8\uC5D0\uC11C \uCDA9\uBD84\uD788
    \uB5A8\uC5B4\uB728\uB9AC\uACE0, \uD68C\uC804\uBD80\uAC00 \uC190\uC774\uB098 \uC5BC\uAD74
    \uBC29\uD5A5\uC73C\uB85C \uD5A5\uD558\uC9C0 \uC54A\uB3C4\uB85D \uC8FC\uC758\uD574\uC57C
    \uD55C\uB2E4\u201D\uACE0 \uC124\uBA85\uD588\uB2E4."
