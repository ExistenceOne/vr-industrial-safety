--- !u!114 &1691823085411928269
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7347239944040847636}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uB178\uD6C4 \uC7A5\uBE44 \uC0AC\uC6A9 \uC911 \uB9DD\uCE58 \uC791\uC5C5
    \uC0AC\uACE0 \uBC1C\uC0DD\r\n\r\n\uACF5\uC7A5 \uC124\uBE44 \uBCF4\uC218 \uC791\uC5C5
    \uC911 \uC791\uC5C5\uC790\uAC00 \uB9DD\uCE58\uB97C \uC0AC\uC6A9\uD574 \uBD80\uD488\uC5D0
    \uBABB\uC744 \uACE0\uC815\uD558\uB358 \uC911 \uC0AC\uACE0\uAC00 \uBC1C\uC0DD\uD588\uB2E4.\r\n\r\n\uC791\uC5C5\uC790\uB294
    \uC791\uC5C5 \uC804 \uC8FC\uBCC0 \uACF5\uAC04\uACFC \uACF5\uAD6C \uC0C1\uD0DC\uB97C
    \uCDA9\uBD84\uD788 \uD655\uC778\uD558\uC9C0 \uC54A\uC558\uC73C\uBA70, \uC9C0\uAE09\uB41C
    \uC7A5\uBE44 \uC911 <u><color=#FFD966>\uC190\uC7A1\uC774\uC640 \uD5E4\uB4DC \uC5F0\uACB0\uBD80\uAC00
    \uB178\uD6C4\uD654\uB41C \uB9DD\uCE58</color></u>\uB97C \uC120\uD0DD\uD574 \uC791\uC5C5\uC744
    \uC2DC\uC791\uD588\uB2E4.\r\n\r\n\uC791\uC5C5 \uC911 \uB9DD\uCE58\uAC00 \uBABB\uC758
    \uC911\uC2EC\uC744 \uC815\uD655\uD788 \uB9DE\uCD94\uC9C0 \uBABB\uD558\uACE0 \uBE57\uB098\uAC00\uBA74\uC11C
    <u><color=#FF6666>\uBE57\uB9DE\uD798 \uC0AC\uACE0</color></u>\uAC00 \uBC1C\uC0DD\uD588\uB2E4.
    \uC774 \uACFC\uC815\uC5D0\uC11C \uB9DD\uCE58 \uBA38\uB9AC \uBD80\uBD84\uC774
    \uACE0\uC815\uD558\uB358 \uC190 \uAC00\uAE4C\uC774\uB85C \uB5A8\uC5B4\uC838 <u><color=#FF6666>\uC190
    \uD0C0\uACA9 \uBC0F \uD611\uCC29 \uC704\uD5D8</color></u>\uC774 \uD655\uC778\uB418\uC5C8\uB2E4.\r\n\r\n\uB610\uD55C
    \uC791\uC5C5\uC790\uAC00 \uACFC\uB3C4\uD55C \uD798\uC73C\uB85C \uB9DD\uCE58\uB97C
    \uD718\uB450\uB974\uBA74\uC11C \uC8FC\uBCC0 \uBD80\uD488\uC5D0 \uCDA9\uACA9\uC774
    \uC804\uB2EC\uB418\uC5C8\uACE0, \uC791\uC740 \uD30C\uD3B8\uC774 \uD280\uC5B4
    \uC791\uC5C5\uC790\uC758 \uC5BC\uAD74 \uBC29\uD5A5\uC73C\uB85C \uB0A0\uC544\uAC00\uB294
    \uC704\uD5D8 \uC0C1\uD669\uC774 \uBC1C\uC0DD\uD588\uB2E4.\r\n\r\n\uD604\uC7A5
    \uAD00\uB9AC\uC790\uB294 \u201C\uB9DD\uCE58 \uC791\uC5C5 \uC804\uC5D0\uB294 \uBC18\uB4DC\uC2DC
    \uBCF4\uD638\uAD6C\uB97C \uCC29\uC6A9\uD558\uACE0, \uC190\uC0C1\uB418\uAC70\uB098
    \uB178\uD6C4\uD654\uB41C \uACF5\uAD6C\uB97C \uC0AC\uC6A9\uD558\uC9C0 \uC54A\uC544\uC57C
    \uD55C\uB2E4. \uB610\uD55C \uD0C0\uACA9 \uC704\uCE58\uB97C \uC815\uD655\uD788
    \uD655\uC778\uD558\uACE0, \uACE0\uC815\uD558\uB294 \uC190\uC774 \uB9DD\uCE58\uC758
    \uD0C0\uACA9 \uBC94\uC704 \uC548\uC5D0 \uB4E4\uC5B4\uAC00\uC9C0 \uC54A\uB3C4\uB85D
    \uC8FC\uC758\uD574\uC57C \uD55C\uB2E4\u201D\uACE0 \uC124\uBA85\uD588\uB2E4."
